# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Plan files
*.tfplan
tfplan_*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include tfvars.example files
!*.tfvars.example

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore Mac .DS_Store files
.DS_Store

# Ignore vim temporary files
*.swp
*.swo
*~

# Ignore VS Code files
.vscode/

# Ignore backup files
*.backup
*.bak

# SSH Keys
*.pem
*.key
id_rsa*
id_ed25519*

# Environment files
.env
.env.*
!.env.example

# AWS credentials (ne jamais commiter!)
.aws/
credentials

# Logs
*.log

# OS specific
Thumbs.db

#secrets
*secret*
