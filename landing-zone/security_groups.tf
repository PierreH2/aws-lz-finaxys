# Security group for app (open HTTP)
resource "aws_security_group" "app_lb" {
  name        = "agentic-research-app-lb"
  description = "Allow HTTP access to app"
  vpc_id      = module.vpc.vpc_id

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }
  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}
